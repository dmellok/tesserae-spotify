{
  "tesserae_compat": "1.x",
  "name": "Spotify, Now Playing",
  "version": "0.2.1",
  "kind": "widget",
  "description": "Currently-playing Spotify track, album art, title, artist, album and progress, in five selectable layouts (split / cover / minimal / vinyl / stack). Requires the Spotify Core plugin (connect your account at Plugins → Spotify).",
  "icon": "ph-music-notes",
  "supports": {
    "sizes": [
      "sm",
      "md",
      "lg"
    ]
  },
  "cell_options": [
    {
      "name": "layout",
      "type": "select",
      "label": "Layout",
      "default": "stack",
      "choices": [
        { "value": "stack", "label": "Stack, art above info" },
        { "value": "side",  "label": "Side, art square on the left" }
      ]
    },
    {
      "name": "show_art",
      "type": "boolean",
      "label": "Show album art",
      "default": true
    },
    {
      "name": "show_album",
      "type": "boolean",
      "label": "Show album name",
      "default": true
    },
    {
      "name": "show_progress",
      "type": "boolean",
      "label": "Show progress bar",
      "default": true
    },
    {
      "name": "show_waveform",
      "type": "boolean",
      "label": "Show track-deterministic waveform glyph",
      "default": true
    }
  ],
  "render": {
    "dither": "floyd-steinberg",
    "needs_network": true
  }
}
